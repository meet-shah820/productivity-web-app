MONGODB_URI=mongodb://127.0.0.1:27017/productivity_app
GEMINI_API_KEY=your_gemini_api_key_here

# Auth
JWT_SECRET=change_me

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
OAUTH_SUCCESS_REDIRECT=http://localhost:5173/auth/callback

# Apple OAuth (optional)
APPLE_CLIENT_ID=your_apple_service_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
# Paste the Apple private key PEM (including BEGIN/END lines)
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
APPLE_CALLBACK_URL=http://localhost:5000/api/auth/apple/callback

# Frontend (Stripe Checkout success/cancel + Customer Portal return_url). Required on Render if Origin/Referer is missing.
# Also used to build /terms and /privacy links shown on Stripe Checkout (custom_text).
FRONTEND_URL=http://localhost:5173

# Stripe (monthly subscriptions)
# On Render: set STRIPE_SECRET_KEY and every STRIPE_PRICE_* in the dashboard only — the server skips loading
# a bundled .env file in production on Render so keys and Price IDs cannot disagree.
# STRIPE_SECRET_KEY and all STRIPE_PRICE_* must be from the SAME Stripe account and SAME mode:
#   sk_test_... + price_... from Test mode, OR sk_live_... + price_... from Live mode.
# Mismatch causes "No such price". After setting vars, run: npm run stripe:verify
#
# Option A: Set STRIPE_SECRET_KEY, then run: npm run stripe:bootstrap
#           Paste the printed STRIPE_PRICE_* lines into .env and Render (do not mix with unrelated Dashboard prices).
# Option B: Dashboard → Products → Pricing → copy each Price ID (price_...), not the Product ID (prod_...).
# Optional display labels (never substitute for real price_ IDs): STRIPE_PRICE_STARTER_LABEL=...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...
# Webhook URL: POST /api/billing/webhook — send at least:
# checkout.session.completed, checkout.session.async_payment_succeeded,
# customer.subscription.(created|updated|deleted), invoice.paid, invoice.payment_failed
#
# Local testing (Stripe CLI):
#   stripe listen --forward-to localhost:5000/api/billing/webhook
#   stripe trigger checkout.session.completed
# Paste the CLI "whsec_..." into STRIPE_WEBHOOK_SECRET while testing.

# Frontend
VITE_API_BASE=
# Dev only: API origin for Vite proxy + leaderboard WebSocket (must match `node server/index.js` port, e.g. http://127.0.0.1:5001 if 5000 is taken)
# VITE_DEV_API_ORIGIN=http://127.0.0.1:5000